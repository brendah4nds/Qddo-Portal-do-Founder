{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A meeting room that can be booked.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the room."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the room."
        }
      },
      "required": ["name"]
    },
    "Booking": {
      "title": "Booking",
      "description": "An appointment for a meeting room.",
      "type": "object",
      "properties": {
        "roomId": {
          "type": "string",
          "description": "The ID of the room being booked."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the booking (YYYY-MM-DD)."
        },
        "startTime": {
          "type": "string",
          "description": "The start time of the booking (HH:mm)."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the booking (HH:mm)."
        },
        "userName": {
          "type": "string",
          "description": "The name of the person booking the room."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the person booking the room."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the booking was created."
        }
      },
      "required": ["roomId", "date", "startTime", "endTime", "userName", "userEmail"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "businessHours": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of available time slots."
        }
      }
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of meeting rooms."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all bookings."
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings."
    }
  }
}
